    "addressLocality": city,
    "addressRegion": state_abbr,
    "addressCountry": "US",
    "postalCode": zip_codes.split(',')[0]
  },
  
  // Entity Relationships
  "containedInPlace": {
    "@type": "State",
    "name": state,
    "url": `https://getuscompliance.com/state/${state.toLowerCase().replace(/\s+/g, '-')}`
  },
