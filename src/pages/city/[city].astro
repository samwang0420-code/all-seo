  // Population & Demographics
  "population": population,
  
  // Additional Entities
  "url": `https://getuscompliance.com/city/${city.toLowerCase().replace(/\s+/g, '-')}-${state_abbr.toLowerCase()}`,
  
  // Related Entities
  "additionalProperty": [
