---
import Layout from '../../layouts/Layout.astro';
import cities from '../../data/cities.json';

// Calculate distance between two cities using Haversine formula
function getDistance(lat1: number, lng1: number, lat2: number, lng2: number) {
  const R = 3959;
  const dLat = (lat2 - lat1) * Math.PI / 180;
  const dLng = (lng2 - lng1) * Math.PI / 180;
  const a = Math.sin(dLat/2) * Math.sin(dLat/2) +
    Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
    Math.sin(dLng/2) * Math.sin(dLng/2);
  const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
  return R * c;
}

export function getStaticPaths() {
  return cities.map(city => ({
    params: { 
      city: `${city.city.toLowerCase().replace(/\s+/g, '-')}-${city.state_abbr.toLowerCase()}` 
    },
    props: { cityData: city }
  }));
}

const { cityData } = Astro.props;
const { city, state, state_abbr, county, population, median_income, median_rent, median_home_value, crime_index, median_age, zip_codes, livability_score, type, lat, lng } = cityData;

const crimeMessage = crime_index < 30 ? "It is exceptionally safe." : crime_index > 80 ? "Caution is advised." : "Crime rates are moderate.";
const livabilityMessage = livability_score >= 8 ? "excellent" : livability_score >= 7 ? "great" : livability_score >= 6 ? "good" : "moderate";

// Find nearby cities (within 150 miles)
const nearbyCities = cities
  .filter(c => c.city !== city || c.state_abbr !== state_abbr)
  .map(c => ({
    ...c,
    distance: getDistance(lat, lng, c.lat, c.lng)
  }))
  .filter(c => c.distance < 150)
  .sort((a, b) => a.distance - b.distance)
  .slice(0, 6);

// Find similar cities (by population size)
const similarCities = cities
  .filter(c => c.city !== city || c.state_abbr !== state_abbr)
  .filter(c => {
    const popRatio = c.population / population;
    return popRatio > 0.7 && popRatio < 1.3;
  })
  .slice(0, 4);

// Cost comparison helpers
const nationalMedianRent = 1470;
const nationalMedianHome = 416100;
const rentComparison = median_rent > nationalMedianRent ? "above" : "below";
const homeComparison = median_home_value > nationalMedianHome ? "above" : "below";

// Weather/climate data (simulated - in real app would come from data)
const climateData = {
  "WA": { climate: "Marine", avgHigh: 59, avgLow: 45, rainfall: 38 },
  "CA": { climate: "Mediterranean", avgHigh: 75, avgLow: 55, rainfall: 15 },
  "TX": { climate: "Subtropical", avgHigh: 85, avgLow: 65, rainfall: 32 },
  "FL": { climate: "Tropical", avgHigh: 84, avgLow: 68, rainfall: 54 },
  "NY": { climate: "Humid Continental", avgHigh: 62, avgLow: 48, rainfall: 42 },
  "AZ": { climate: "Desert", avgHigh: 92, avgLow: 58, rainfall: 8 },
  "CO": { climate: "Semi-Arid", avgHigh: 67, avgLow: 35, rainfall: 14 },
  "NV": { climate: "Desert", avgHigh: 85, avgLow: 52, rainfall: 10 },
  "IL": { climate: "Humid Continental", avgHigh: 64, avgLow: 46, rainfall: 36 },
  "GA": { climate: "Humid Subtropical", avgHigh: 77, avgLow: 58, rainfall: 48 },
};

const climate = climateData[state_abbr] || { climate: "Moderate", avgHigh: 70, avgLow: 50, rainfall: 35 };

// JSON-LD Knowledge Graph
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "City",
  "name": `${city}, ${state_abbr}`,
  "description": `Comprehensive guide to ${city}, ${state} including cost of living, demographics, climate, education, healthcare, and employment. Population: ${population.toLocaleString()}.`,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": city,
    "addressRegion": state_abbr,
    "addressCountry": "US"
  },
  "population": population,
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": lat,
    "longitude": lng
  },
  "url": `https://getuscompliance.com/city/${city.toLowerCase().replace(/\s+/g, '-')}-${state_abbr.toLowerCase()}`,
  "containedInPlace": {
    "@type": "State",
    "name": state
  },
  "partOf": {
    "@type": "County",
    "name": county + " County"
  }
};

// FAQ data for People Also Ask
const faqs = [
  {
    question: `What is the cost of living in ${city}, ${state_abbr}?`,
    answer: `The cost of living in ${city} is ${median_rent > nationalMedianRent ? 'higher' : 'lower'} than the national average. Median rent is $${median_rent}/month and median home value is $${median_home_value.toLocaleString()}.`
  },
  {
    question: `Is ${city}, ${state_abbr} safe?`,
    answer: `${city} has a crime index of ${crime_index}. ${crimeMessage}`
  },
  {
    question: `What is the population of ${city}, ${state_abbr}?`,
    answer: `The population of ${city} is ${population.toLocaleString()}.`
  },
  {
    question: `What is the median income in ${city}, ${state_abbr}?`,
    answer: `The median household income in ${city} is $${median_income.toLocaleString()}.`
  },
  {
    question: `What is the weather like in ${city}, ${state_abbr}?`,
    answer: `${city} has a ${climate.climate} climate with average high of ${climate.avgHigh}°F and low of ${climate.avgLow}°F.`
  }
];
---

<Layout 
  title={`${city}, ${state_abbr} Cost of Living, Crime Rate, Demographics & Complete Guide (2026)`}
  description={`Complete guide to ${city}, ${state}. Discover cost of living, housing prices, crime rates, demographics, climate, schools, healthcare, employment and more.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  
  <div class="max-w-5xl mx-auto px-4 py-8">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-600 mb-6">
      <a href="/" class="hover:text-blue-600">Home</a> / 
      <a href={`/state/${state.toLowerCase().replace(/\s+/g, '-')}`} class="hover:text-blue-600">{state}</a> / 
      <span class="text-gray-900">{city}</span>
    </nav>

    <!-- Header -->
    <header class="mb-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">{city}, {state_abbr}</h1>
      <p class="text-xl text-gray-600">
        {city} is a {type} located in {county} County, {state}. 
        With a population of <strong>{population.toLocaleString()}</strong>, it offers an urban feel. 
        The median household income is <strong>${median_income.toLocaleString()}</strong>.
      </p>
    </header>

    <!-- Quick Stats Cards -->
    <section class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-blue-50 p-4 rounded-lg text-center">
        <p class="text-sm text-gray-600">Population</p>
        <p class="text-2xl font-bold text-blue-600">{population.toLocaleString()}</p>
      </div>
      <div class="bg-green-50 p-4 rounded-lg text-center">
        <p class="text-sm text-gray-600">Median Home</p>
        <p class="text-2xl font-bold text-green-600">${(median_home_value/1000).toFixed(0)}K</p>
      </div>
      <div class="bg-purple-50 p-4 rounded-lg text-center">
        <p class="text-sm text-gray-600">Crime Index</p>
        <p class="text-2xl font-bold text-purple-600">{crime_index}</p>
      </div>
      <div class="bg-orange-50 p-4 rounded-lg text-center">
        <p class="text-sm text-gray-600">Livability</p>
        <p class="text-2xl font-bold text-orange-600">{livability_score}/10</p>
      </div>
    </section>

    <!-- Cost of Living -->
    <section class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-2xl font-bold mb-4">💰 Cost of Living in {city}</h2>
      <p class="text-gray-600 mb-6">
        Understanding the cost of living is essential when considering a move to {city}, {state}. 
        Here's a detailed breakdown of housing costs compared to national averages.
      </p>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 bg-blue-50 rounded-lg">
          <p class="text-gray-600 mb-1">Median Rent</p>
          <p class="text-4xl font-bold text-blue-600">${median_rent}<span class="text-lg font-normal">/month</span></p>
          <p class="text-sm mt-2">
            {rentComparison === "above" ? "📈" : "📉"} {rentComparison === "above" ? "Higher" : "Lower"} than national average (${nationalMedianRent})
          </p>
        </div>
        <div class="p-6 bg-green-50 rounded-lg">
          <p class="text-gray-600 mb-1">Median Home Value</p>
          <p class="text-4xl font-bold text-green-600">${median_home_value.toLocaleString()}</p>
          <p class="text-sm mt-2">
            {homeComparison === "above" ? "📈" : "📉"} {homeComparison === "above" ? "Higher" : "Lower"} than national average (${nationalMedianHome.toLocaleString()})
          </p>
        </div>
      </div>
      <div class="mt-6 p-4 bg-gray-50 rounded-lg">
        <h3 class="font-semibold mb-2">💡 Cost of Living Summary</h3>
        <p class="text-gray-600">
          {city} is generally considered {median_home_value > nationalMedianHome ? "an expensive" : "an affordable"} place to live. 
          Housing costs are {homeComparison} the national average, while rent prices follow a similar trend.
        </p>
      </div>
    </section>

    <!-- Crime & Safety -->
    <section class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-2xl font-bold mb-4">🔒 Crime & Safety in {city}</h2>
      <div class="flex items-center gap-4 mb-4">
        <div class="text-5xl font-bold text-{crime_index < 40 ? 'green' : crime_index > 70 ? 'red' : 'yellow'}-600">
          {crime_index}
        </div>
        <div>
          <p class="text-lg font-semibold">Crime Index</p>
          <p class="text-gray-600">{crimeMessage}</p>
        </div>
      </div>
      <p class="text-gray-600">
        The crime rate in {city} is {crime_index < 40 ? "relatively low" : crime_index > 70 ? "relatively high" : "moderate"} compared to other US cities. 
        When considering safety, it's important to look at both violent crime and property crime rates specific to neighborhoods within {city}.
      </p>
    </section>

    <!-- Demographics -->
    <section class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-2xl font-bold mb-4">👥 Demographics & Population</h2>
      <div class="grid md:grid-cols-3 gap-6 mb-6">
        <div>
          <p class="text-gray-600">Population</p>
          <p class="text-3xl font-bold">{population.toLocaleString()}</p>
        </div>
        <div>
          <p class="text-gray-600">Median Age</p>
          <p class="text-3xl font-bold">{median_age}</p>
        </div>
        <div>
          <p class="text-gray-600">Median Household Income</p>
          <p class="text-3xl font-bold">${median_income.toLocaleString()}</p>
        </div>
      </div>
      <p class="text-gray-600">
        {city} has a diverse population with a median age of {median_age}. 
        The city attracts residents from various backgrounds, contributing to its vibrant community.
      </p>
    </section>

    <!-- Climate & Weather -->
    <section class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-2xl font-bold mb-4">🌤️ Climate & Weather in {city}</h2>
      <div class="grid md:grid-cols-4 gap-4 mb-6">
        <div class="text-center p-4 bg-yellow-50 rounded-lg">
          <p class="text-3xl mb-2">☀️</p>
          <p class="text-gray-600">Climate</p>
          <p class="font-bold">{climate.climate}</p>
        </div>
        <div class="text-center p-4 bg-red-50 rounded-lg">
          <p class="text-3xl mb-2">📈</p>
          <p class="text-gray-600">Avg High</p>
          <p class="font-bold">{climate.avgHigh}°F</p>
        </div>
        <div class="text-center p-4 bg-blue-50 rounded-lg">
          <p class="text-3xl mb-2">📉</p>
          <p class="text-gray-600">Avg Low</p>
          <p class="font-bold">{climate.avgLow}°F</p>
        </div>
        <div class="text-center p-4 bg-gray-50 rounded-lg">
          <p class="text-3xl mb-2">🌧️</p>
          <p class="text-gray-600">Rainfall</p>
          <p class="font-bold">{climate.rainfall} in/year</p>
        </div>
      </div>
      <p class="text-gray-600">
        {city} features a {climate.climate.toLowerCase()} climate, making it attractive for those who enjoy {climate.climate.includes("Sunny") || climate.climate.includes("Desert") ? "year-round sunshine" : "varied seasonal weather"}. 
        Consider your climate preferences when choosing {city} as your new home.
      </p>
    </section>

    <!-- Employment & Economy -->
    <section class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-2xl font-bold mb-4">💼 Employment & Economy</h2>
      <p class="text-gray-600 mb-4">
        {city} offers a diverse economy with opportunities in various sectors. The median household income of 
        <strong>${median_income.toLocaleString()}</strong> reflects the economic opportunities available.
      </p>
      <div class="p-4 bg-green-50 rounded-lg">
        <p class="font-semibold mb-2">💡 Economic Insight</p>
        <p class="text-gray-600">
          {median_income > 75000 ? "This city has a strong economy with above-average income levels." : "This city offers affordable living with moderate income levels."}
        </p>
      </div>
    </section>

    <!-- Education -->
    <section class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-2xl font-bold mb-4">🎓 Education & Schools</h2>
      <p class="text-gray-600 mb-4">
        Education quality is a crucial factor for families considering relocation to {city}. 
        The median age of {median_age} suggests a mix of young families and established residents.
      </p>
      <div class="grid md:grid-cols-2 gap-4">
        <div class="p-4 border rounded-lg">
          <h3 class="font-semibold mb-2">🏫 K-12 Education</h3>
          <p class="text-gray-600">Local school districts serve students from kindergarten through high school.</p>
        </div>
        <div class="p-4 border rounded-lg">
          <h3 class="font-semibold mb-2">🎓 Higher Education</h3>
          <p class="text-gray-600">{city} has access to colleges and universities in the greater {state} area.</p>
        </div>
      </div>
    </section>

    <!-- Healthcare -->
    <section class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-2xl font-bold mb-4">🏥 Healthcare</h2>
      <p class="text-gray-600">
        Access to quality healthcare is essential. {city} offers various healthcare facilities and medical services 
        to meet the needs of its residents.
      </p>
    </section>

    <!-- Transportation -->
    <section class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-2xl font-bold mb-4">🚗 Transportation</h2>
      <p class="text-gray-600">
        Getting around {city} is facilitated by major highways and transportation infrastructure. 
        The city's layout offers various options for commuters and residents.
      </p>
    </section>

    <!-- FAQ (People Also Ask) -->
    <section class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-2xl font-bold mb-4">❓ Frequently Asked Questions</h2>
      <div class="space-y-6">
        {faqs.map((faq) => (
          <div class="border-b pb-4">
            <h3 class="font-semibold mb-2">{faq.question}</h3>
            <p class="text-gray-600">{faq.answer}</p>
          </div>
        ))}
        <div class="border-b pb-4">
          <h3 class="font-semibold mb-2">What are the zip codes for {city}, {state_abbr}?</h3>
          <p class="text-gray-600">The zip codes for {city} include: {zip_codes}.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-2">Is {city} a good place to live?</h3>
          <p class="text-gray-600">
            Based on a livability score of {livability_score}/10, {city} is considered a {livabilityMessage} place to live. 
            Factors like cost of living, safety, and amenities contribute to this rating.
          </p>
        </div>
      </div>
    </section>

    <!-- Nearby Cities (GEO) -->
    {nearbyCities.length > 0 && (
      <section class="bg-white rounded-lg shadow-md p-6 mb-8">
        <h2 class="text-2xl font-bold mb-4">📍 Nearby Cities</h2>
        <p class="text-gray-600 mb-4">Explore cities within 150 miles of {city}:</p>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
          {nearbyCities.map((nearby) => (
            <a 
              href={`/city/${nearby.city.toLowerCase().replace(/\s+/g, '-')}-${nearby.state_abbr.toLowerCase()}`}
              class="block p-4 border rounded-lg hover:border-blue-500 hover:bg-blue-50 transition"
            >
              <h3 class="font-semibold text-blue-600">{nearby.city}, {nearby.state_abbr}</h3>
              <p class="text-sm text-gray-600">{Math.round(nearby.distance)} miles away</p>
              <p class="text-sm text-gray-500">Pop: {nearby.population.toLocaleString()}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Similar Cities -->
    {similarCities.length > 0 && (
      <section class="bg-white rounded-lg shadow-md p-6 mb-8">
        <h2 class="text-2xl font-bold mb-4">🔄 Similar Cities</h2>
        <p class="text-gray-600 mb-4">Cities with similar population sizes:</p>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
          {similarCities.map((similar) => (
            <a 
              href={`/city/${similar.city.toLowerCase().replace(/\s+/g, '-')}-${similar.state_abbr.toLowerCase()}`}
              class="block p-4 border rounded-lg hover:border-green-500 hover:bg-green-50 transition"
            >
              <h3 class="font-semibold text-green-600">{similar.city}, {similar.state_abbr}</h3>
              <p class="text-sm text-gray-600">Pop: {similar.population.toLocaleString()}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Related State -->
    <section class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-2xl font-bold mb-4">🗺️ More Cities in {state}</h2>
      <p class="text-gray-600 mb-4">Explore other cities in {state}:</p>
      <a 
        href={`/state/${state.toLowerCase().replace(/\s+/g, '-')}`}
        class="inline-block bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition"
      >
        View All {state} Cities →
      </a>
    </section>
  </div>
</Layout>
