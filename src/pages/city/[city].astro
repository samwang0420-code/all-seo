    <!-- Header -->
    <header class="mb-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">{city}, {state_abbr}</h1>
      <p class="text-xl text-gray-600">
        {city} is a {type} located in <strong>{county} County</strong>, {state}. 
        Population: <strong>{population.toLocaleString()}</strong> | 
        Time Zone: <strong>{entity.timezone}</strong>
