---

<Layout 
  title={`${city}, ${state_abbr} Complete Guide: Cost of Living, Demographics, Geography, Transportation & More (2026)`}
  description={`Ultimate guide to ${city}, ${state}. Comprehensive data on cost of living, population, geography, transportation, area codes, airports, highways, weather, and local information.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  
  <div class="max-w-5xl mx-auto px-4 py-8">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-600 mb-6">
      <a href="/" class="hover:text-blue-600">Home</a> / 
      <a href={`/state/${state.toLowerCase().replace(/\s+/g, '-')}`} class="hover:text-blue-600">{state}</a> / 
      <span class="text-gray-900">{city}</span>
