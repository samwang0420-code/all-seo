  .map(c => ({
    ...c,
    distance: getDistance(lat, lng, c.lat, c.lng)
  }))
  .filter(c => c.distance < 150)
  .sort((a, b) => a.distance - b.distance)
  .slice(0, 6);

// Find similar cities (by population size)
