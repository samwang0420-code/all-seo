      "name": "TimeZone",
      "value": displayTimezone
    },
    {
      "@type": "PropertyValue",
      "name": "AreaCode",
      "value": entity.areaCodes.join(', ')
    },
    {
      "@type": "PropertyValue",
      "name": "ZIPCodes",
      "value": zip_codes
    },
    {
      "@type": "PropertyValue",
      "name": "MedianHouseholdIncome",
      "value": median_income
    },
    {
      "@type": "PropertyValue",
      "name": "MedianHomeValue",
      "value": median_home_value
    },
    {
      "@type": "PropertyValue",
      "name": "CrimeIndex",
      "value": crime_index
    }
  ]
};

// FAQ for People Also Ask
const faqs = [
  { question: `What is ${city}, ${state_abbr} known for?`, answer: `${city} is a ${type} known for its ${type.includes('tech') ? 'technology industry' : type.includes('coastal') ? 'coastal location and beaches' : 'unique character and attractions'}.` },
  { question: `What is the cost of living in ${city}, ${state_abbr}?`, answer: `Median rent is $${median_rent}/month and median home value is $${median_home_value.toLocaleString()}.` },
  { question: `Is ${city}, ${state_abbr} safe?`, answer: `Crime index is ${crime_index}. ${crimeMessage}` },
  { question: `What is the population of ${city}, ${state_abbr}?`, answer: `Population is ${population.toLocaleString()}.` },
  { question: `What is the weather like in ${city}, ${state_abbr}?`, answer: `${city} has a ${climate.climate} climate with average highs of ${climate.avgHigh}°F.` },
  { question: `What are the main highways in ${city}, ${state_abbr}?`, answer: `Major highways include: ${entity.majorHighways.join(', ') || 'Various local highways'}.` },
  { question: `What is the major airport serving ${city}, ${state_abbr}?`, answer: `The main airport is ${entity.airport}.` },
  { question: `What time zone is ${city}, ${state_abbr} in?`, answer: `${city} is in the ${entity.timezone} time zone.` },
  { question: `What are the area codes for ${city}, ${state_abbr}?`, answer: `Area codes include: ${entity.areaCodes.join(', ')}.` },
  { question: `What county is ${city}, ${state_abbr} in?`, answer: `${city} is located in ${county} County.` }
];
---

<Layout 
  title={`${city}, ${state_abbr} (2026): ${population.toLocaleString()} Population, Cost of Living, Crime Rate & Liveability Score`}
  description={`Ultimate guide to ${city}, ${state}. Comprehensive data on cost of living, population, geography, transportation, area codes, airports, highways, weather, and local information.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  
  {/* FAQ Schema for AI Search */}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  })} />
  
  {/* HowTo Schema for City Evaluation */}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": `How to Evaluate ${city}, ${state_abbr} for Living`,
    "description": `Step-by-step guide to evaluating ${city} based on cost, safety, and amenities.`,
    "step": [
      { "@type": "HowToStep", "name": "Check Cost of Living", "text": `Home $${median_home_value.toLocaleString()}, Rent $${median_rent}/mo` },
      { "@type": "HowToStep", "name": "Evaluate Safety", "text": `Crime index ${crime_index}. ${crimeMessage}` },
      { "@type": "HowToStep", "name": "Review Local Amenities", "text": `Major businesses: Walmart, CVS, etc. Timezone: ${entity.timezone}` }
    ]
  })} />
  
  <div class="max-w-5xl mx-auto px-4 py-8">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-600 mb-6">
      <a href="/" class="hover:text-blue-600">Home</a> / 
      <a href={`/state/${state.toLowerCase().replace(/\s+/g, '-')}`} class="hover:text-blue-600">{state}</a> / 
      <span class="text-gray-900">{city}</span>
    </nav>

    <!-- Header -->
    <header class="mb-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">{city}, {state_abbr}</h1>
      {ai_introduction && (
        <p class="text-lg text-gray-700 mb-4 leading-relaxed">{ai_introduction}</p>
      )}
      <p class="text-xl text-gray-600">
        {city} is a {type} located in <strong>{county} County</strong>, {state}. 
        Population: <strong>{population.toLocaleString()}</strong> | 
        Time Zone: <strong>{entity.timezone}</strong>
      </p>
    </header>

    <!-- Executive Summary for AI Search -->
    <section class="bg-gradient-to-r from-blue-50 to-green-50 rounded-lg p-6 mb-8 border-l-4 border-blue-500">
      <h2 class="text-lg font-bold mb-2">📋 Executive Summary</h2>
      <div class="text-gray-700 space-y-2">
        <p><strong>Population:</strong> {population.toLocaleString()} | <strong>County:</strong> {county} County | <strong>State:</strong> {state}</p>
        <p><strong>Cost of Living:</strong> Median home ${median_home_value.toLocaleString()} | Median rent ${median_rent.toLocaleString()}/month | Median income ${median_income.toLocaleString()}</p>
        <p><strong>Safety:</strong> Crime index {crime_index} ({crimeMessage}) | <strong>Livability:</strong> {livability_score}/10</p>
        <p><strong>Location:</strong> {lat.toFixed(4)}°N, {Math.abs(lng).toFixed(4)}°W | <strong>Timezone:</strong> {entity.timezone}</p>
      </div>
    </section>

    <!-- Quick Stats -->
    <section class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-blue-50 p-4 rounded-lg text-center">
        <p class="text-sm text-gray-600">Population</p>
        <p class="text-2xl font-bold text-blue-600">{population.toLocaleString()}</p>
      </div>
      <div class="bg-green-50 p-4 rounded-lg text-center">
        <p class="text-sm text-gray-600">Median Home</p>
        <p class="text-2xl font-bold text-green-600">${(median_home_value/1000).toFixed(0)}K</p>
      </div>
      <div class="bg-purple-50 p-4 rounded-lg text-center">
        <p class="text-sm text-gray-600">Crime Index</p>
        <p class="text-2xl font-bold text-purple-600">{crime_index}</p>
      </div>
      <div class="bg-orange-50 p-4 rounded-lg text-center">
        <p class="text-sm text-gray-600">Livability</p>
        <p class="text-2xl font-bold text-orange-600">{livability_score}/10</p>
      </div>
    </section>

    <!-- Geographic & Location Entity -->
    <section class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-2xl font-bold mb-4">📍 Geographic & Location Information</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <h3 class="font-semibold mb-3">🗺️ Location Details</h3>
          <ul class="space-y-2 text-gray-600">
            <li><strong>City:</strong> {city}</li>
            <li><strong>State:</strong> <a href={`/state/${state.toLowerCase().replace(/\s+/g, '-')}`} class="text-blue-600 hover:underline">{state}</a></li>
            <li><strong>County:</strong> <a href={`/county/${county.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}-${state_abbr.toLowerCase()}`} class="text-blue-600 hover:underline">{county} County</a></li>
            <li><strong>Coordinates:</strong> {lat.toFixed(4)}°N, {Math.abs(lng).toFixed(4)}°{lng < 0 ? 'W' : 'E'}</li>
            <li><strong>ZIP Codes:</strong> {zip_codes}</li>
            <li><strong>Area Codes:</strong> {entity.areaCodes.join(', ')}</li>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold mb-3">🌐 Time & Transportation</h3>
          <ul class="space-y-2 text-gray-600">
            <li><strong>Time Zone:</strong> {displayTimezone}</li>
            <li><strong>Major Airport:</strong> {entity.airport}</li>
            <li><strong>Major Highways:</strong> {entity.majorHighways.join(', ') || 'Various'}</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Cost of Living -->
    <section class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-2xl font-bold mb-4">💰 Cost of Living in {city}</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 bg-blue-50 rounded-lg">
          <p class="text-gray-600 mb-1">Median Rent</p>
          <p class="text-4xl font-bold text-blue-600">${median_rent}<span class="text-lg font-normal">/month</span></p>
        </div>
        <div class="p-6 bg-green-50 rounded-lg">
          <p class="text-gray-600 mb-1">Median Home Value</p>
          <p class="text-4xl font-bold text-green-600">${median_home_value.toLocaleString()}</p>
        </div>
      </div>
    </section>

    <!-- Crime & Safety -->
    <section class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-2xl font-bold mb-4">🔒 Crime & Safety in {city}</h2>
      <div class="flex items-center gap-4">
        <div class="text-5xl font-bold text-{crime_index < 40 ? 'green' : crime_index > 70 ? 'red' : 'yellow'}-600">
          {crime_index}
        </div>
        <div>
          <p class="text-lg font-semibold">Crime Index</p>
          <p class="text-gray-600">{crimeMessage}</p>
        </div>
      </div>
    </section>

    <!-- Demographics -->
    <section class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-2xl font-bold mb-4">👥 Demographics</h2>
      <div class="grid md:grid-cols-4 gap-6">
        <div><p class="text-gray-600">Population</p><p class="text-3xl font-bold">{population.toLocaleString()}</p></div>
        <div><p class="text-gray-600">Density</p><p class="text-3xl font-bold">{density ? density.toLocaleString() + '/mi²' : 'N/A'}</p></div>
        <div><p class="text-gray-600">Median Age</p><p class="text-3xl font-bold">{median_age}</p></div>
        <div><p class="text-gray-600">Median Income</p><p class="text-3xl font-bold">${median_income.toLocaleString()}</p></div>
      </div>
    </section>

    <!-- Climate -->
    <section class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-2xl font-bold mb-4">🌤️ Climate & Weather</h2>
      <div class="grid md:grid-cols-4 gap-4">
        <div class="text-center p-4 bg-yellow-50 rounded-lg">
          <p class="text-3xl mb-2">☀️</p><p class="text-gray-600">Climate</p><p class="font-bold">{climate.climate}</p>
        </div>
        <div class="text-center p-4 bg-red-50 rounded-lg">
          <p class="text-3xl mb-2">📈</p><p class="text-gray-600">Avg High</p><p class="font-bold">{climate.avgHigh}°F</p>
        </div>
        <div class="text-center p-4 bg-blue-50 rounded-lg">
          <p class="text-3xl mb-2">📉</p><p class="text-gray-600">Avg Low</p><p class="font-bold">{climate.avgLow}°F</p>
        </div>
        <div class="text-center p-4 bg-gray-50 rounded-lg">
          <p class="text-3xl mb-2">🌧️</p><p class="text-gray-600">Rainfall</p><p class="font-bold">{climate.rainfall} in/year</p>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-2xl font-bold mb-4">❓ Frequently Asked Questions</h2>
      <div class="space-y-6">
        {faqs.map((faq) => (
          <div class="border-b pb-4">
            <h3 class="font-semibold mb-2">{faq.question}</h3>
            <p class="text-gray-600">{faq.answer}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Nearby Cities (GEO) -->
    {nearbyCities.length > 0 && (
      <section class="bg-white rounded-lg shadow-md p-6 mb-8">
        <h2 class="text-2xl font-bold mb-4">📍 Nearby Cities (Within 100 miles)</h2>
        <p class="text-gray-600 mb-4">Cities close to {city} - easy day trips or commuting options</p>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
          {nearbyCities.map((nearby) => (
            <a href={`/city/${nearby.city.toLowerCase().replace(/\s+/g, '-')}-${nearby.state_abbr.toLowerCase()}`} class="block p-3 md:p-4 border rounded-lg hover:border-blue-500 hover:bg-blue-50">
              <h3 class="font-semibold text-blue-600">{nearby.city}, {nearby.state_abbr}</h3>
              <p class="text-sm text-gray-600">{Math.round(nearby.distance)} miles away</p>
              <p class="text-xs text-gray-400">Pop: {nearby.population.toLocaleString()}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Regional Cities (GEO) -->
    {regionalCities.length > 0 && (
      <section class="bg-white rounded-lg shadow-md p-6 mb-8">
        <h2 class="text-2xl font-bold mb-4">🌎 Cities in {currentRegion} Region</h2>
        <p class="text-gray-600 mb-4">Other cities in the {currentRegion} United States</p>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
          {regionalCities.map((r) => (
            <a href={`/city/${r.city.toLowerCase().replace(/\s+/g, '-')}-${r.state_abbr.toLowerCase()}`} class="block p-3 md:p-4 border rounded-lg hover:border-green-500 hover:bg-green-50">
              <h3 class="font-semibold text-green-600">{r.city}, {r.state_abbr}</h3>
              <p class="text-sm text-gray-600">{r.state}</p>
              <p class="text-xs text-gray-400">Pop: {r.population.toLocaleString()}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Cost Comparison Cities -->
    <section class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-2xl font-bold mb-4">💰 Cost of Living Comparison</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {/* Cheaper Alternatives */}
        {cheaperCities.length > 0 && (
          <div>
            <h3 class="text-lg font-semibold mb-3 text-green-600">🏠 More Affordable Cities</h3>
            <p class="text-sm text-gray-500 mb-3">Similar size, lower cost of living</p>
            <div class="space-y-2">
              {cheaperCities.slice(0, 4).map((c) => (
                <a href={`/city/${c.city.toLowerCase().replace(/\s+/g, '-')}-${c.state_abbr.toLowerCase()}`} class="block p-3 md:p-3 border rounded-lg hover:bg-green-50 flex justify-between">
                  <span class="text-blue-600">{c.city}, {c.state_abbr}</span>
                  <span class="text-green-600">${(c.median_home_value/1000).toFixed(0)}K</span>
                </a>
              ))}
            </div>
          </div>
        )}
        {/* More Expensive */}
        {expensiveCities.length > 0 && (
          <div>
            <h3 class="text-lg font-semibold mb-3 text-purple-600">🏙️ Higher Cost Cities</h3>
            <p class="text-sm text-gray-500 mb-3">Similar size, higher cost of living</p>
            <div class="space-y-2">
              {expensiveCities.slice(0, 4).map((c) => (
                <a href={`/city/${c.city.toLowerCase().replace(/\s+/g, '-')}-${c.state_abbr.toLowerCase()}`} class="block p-3 md:p-3 border rounded-lg hover:bg-purple-50 flex justify-between">
                  <span class="text-blue-600">{c.city}, {c.state_abbr}</span>
                  <span class="text-purple-600">${(c.median_home_value/1000).toFixed(0)}K</span>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </section>

    <!-- Similar Size Cities -->
    {similarCities.length > 0 && (
      <section class="bg-white rounded-lg shadow-md p-6 mb-8">
        <h2 class="text-2xl font-bold mb-4">👥 Similar Size Cities</h2>
        <p class="text-gray-600 mb-4">Cities with similar population sizes across the US</p>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
          {similarCities.map((s) => (
            <a href={`/city/${s.city.toLowerCase().replace(/\s+/g, '-')}-${s.state_abbr.toLowerCase()}`} class="block p-3 md:p-4 border rounded-lg hover:border-orange-500 hover:bg-orange-50">
              <h3 class="font-semibold text-orange-600">{s.city}, {s.state_abbr}</h3>
              <p class="text-sm text-gray-600">Pop: {s.population.toLocaleString()}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- More Cities in State -->
    <section class="bg-white rounded-lg shadow-md p-4 md:p-6">
      <h2 class="text-xl md:text-2xl font-bold mb-4">🗺️ More Cities in {state}</h2>
      <a href={`/state/${state.toLowerCase().replace(/\s+/g, '-')}`} class="inline-block bg-blue-600 text-white px-5 py-3 md:px-6 md:py-3 rounded-lg hover:bg-blue-700 text-base md:text-lg w-full md:w-auto text-center no-select">
        View All {state} Cities →
      </a>
    </section>

    {/* Businesses in {city} */}
    {(() => {
      const cityBizKey = `${city.toLowerCase()}-${state_abbr.toLowerCase()}`;
      const cityBiz = cityBusinesses[cityBizKey];
      if (!cityBiz || Object.keys(cityBiz).length === 0) return null;
      const bizEntries = Object.entries(cityBiz).filter(([_, stores]) => stores.length > 0);
      if (bizEntries.length === 0) return null;
      return (
        <section class="bg-white rounded-lg shadow-md p-4 md:p-6">
          <h2 class="text-xl md:text-2xl font-bold mb-4">🏪 Businesses in {city}</h2>
          <p class="text-gray-600 mb-4">Major retail chains and businesses located in {city}</p>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
            {bizEntries.map(([bizName, stores]) => (
              <div class="border rounded-lg p-4">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-2xl">{businessIcons[bizName] || '🏪'}</span>
                  <h3 class="font-semibold">{businessNames[bizName] || bizName}</h3>
                </div>
                <p class="text-sm text-gray-600">{stores.length} location{stores.length !== 1 ? 's' : ''}</p>
              </div>
            ))}
          </div>
        </section>
      );
    })()}

    <!-- Neighborhoods (for supported cities) -->
    {(() => {
      const cityKey = `${city}-${state}`;
      const cityNeighborhoods = neighborhoods.cities[cityKey];
      if (!cityNeighborhoods) return null;
      const sampleNeighborhoods = cityNeighborhoods.neighborhoods.slice(0, 20);
      return (
        <section class="bg-white rounded-lg shadow-md p-4 md:p-6">
          <h2 class="text-xl md:text-2xl font-bold mb-4">🏘️ Neighborhoods in {city}</h2>
          <p class="text-gray-600 mb-4">{cityNeighborhoods.neighborhoods.length} neighborhoods available</p>
          <div class="flex flex-wrap gap-2 mb-4">
            {sampleNeighborhoods.map(n => (
              <a href={`/neighborhood/${city.toLowerCase().replace(/\s+/g, '-')}-${state.toLowerCase().replace(/\s+/g, '-')}/${n.url_name || n.name.toLowerCase().replace(/\s+/g, '-')}`}
                 class="px-3 py-1 bg-gray-200 hover:bg-gray-300 rounded-full text-sm transition-colors">
                {n.name}
              </a>
            ))}
          </div>
          {cityNeighborhoods.neighborhoods.length > 20 && (
            <a href={`/neighborhood/${city.toLowerCase().replace(/\s+/g, '-')}-${state.toLowerCase().replace(/\s+/g, '-')}/`}
               class="text-blue-600 hover:underline">
              View all {cityNeighborhoods.neighborhoods.length} neighborhoods →
            </a>
          )}
        </section>
      );
    })()}
  </div>
</Layout>
