// Use real timezone from data, fallback to state-level entity
const displayTimezone = timezone || entity.timezone;

// Regional groupings for GEO
const regions = {
  "Northeast": ["CT", "ME", "MA", "NH", "RI", "VT", "NJ", "NY", "PA"],
  "Midwest": ["IL", "IN", "MI", "OH", "WI", "IA", "KS", "MN", "MO", "NE", "ND", "SD"],
  "South": ["DE", "FL", "GA", "MD", "NC", "SC", "VA", "DC", "WV", "AL", "KY", "MS", "TN", "AR", "LA", "OK", "TX"],
  "West": ["AZ", "CO", "ID", "MT", "NV", "NM", "UT", "WY", "AK", "CA", "HI", "OR", "WA"]
};

const currentRegion = Object.entries(regions).find(([_, states]) => states.includes(state_abbr))?.[0] || "Other";

// Find nearby cities (within 100 miles)
const nearbyCities = cities
  .filter(c => c.city !== city || c.state_abbr !== state_abbr)
  .map(c => ({
    ...c,
    distance: getDistance(lat, lng, c.lat, c.lng)
  }))
  .filter(c => c.distance < 100)
  .sort((a, b) => a.distance - b.distance)
  .slice(0, 8);

// Find regional cities (same region, different state)
const regionalCities = cities
  .filter(c => c.state_abbr !== state_abbr && regions[currentRegion]?.includes(c.state_abbr))
  .slice(0, 6);

// Find similar cities (by population size +/- 30%)
const similarCities = cities
  .filter(c => c.city !== city || c.state_abbr !== state_abbr)
  .filter(c => {
    const popRatio = c.population / population;
    return popRatio > 0.7 && popRatio < 1.3;
  })
  .slice(0, 6);

// Find cheaper alternatives (similar population, lower cost of living)
const cheaperCities = cities
  .filter(c => c.city !== city || c.state_abbr !== state_abbr)
  .filter(c => c.median_home_value < median_home_value * 0.85 && c.population > population * 0.5)
  .slice(0, 6);

// Find more expensive cities (similar population, higher cost)
const expensiveCities = cities
  .filter(c => c.city !== city || c.state_abbr !== state_abbr)
  .filter(c => c.median_home_value > median_home_value * 1.15 && c.population > population * 0.5)
  .slice(0, 6);

// Cost comparison
const nationalMedianRent = 1470;
const nationalMedianHome = 416100;

