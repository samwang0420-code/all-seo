---
import Layout from '../../layouts/Layout.astro';
import cities from '../../data/cities.json';

export function getStaticPaths() {
  const states = [...new Set(cities.map(c => c.state))];
  return states.map(state => ({
    params: { state: state.toLowerCase().replace(/\s+/g, '-') },
    props: { stateName: state }
  }));
}

const { stateName } = Astro.props;
const stateCities = cities.filter(c => c.state === stateName).sort((a, b) => a.city.localeCompare(b.city));
---

<Layout title={`Cost of Living & Statistics in ${stateName}`}>
  <div class="max-w-7xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-8">Cost of Living & Statistics in {stateName}</h1>
    
    <div class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-2xl font-semibold mb-4">Overview</h2>
      <p class="text-gray-600">
        {stateName} has {stateCities.length} cities in our database. 
        Browse through to find detailed information about cost of living, crime rates, and demographics.
      </p>
    </div>

    <h2 class="text-2xl font-bold mb-6">Cities in {stateName} (A-Z)</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {stateCities.map((city) => (
        <a 
          href={`/city/${city.city.toLowerCase().replace(/\s+/g, '-')}-${city.state_abbr.toLowerCase()}`}
          class="block bg-white rounded-lg shadow p-4 hover:shadow-md transition-shadow"
        >
          <h3 class="text-lg font-semibold text-blue-600">{city.city}</h3>
          <p class="text-sm text-gray-600">Population: {city.population.toLocaleString()}</p>
        </a>
      ))}
    </div>
  </div>
</Layout>
