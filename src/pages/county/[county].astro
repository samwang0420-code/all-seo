---
import Layout from '../../layouts/Layout.astro';
import counties from '../../data/counties.json';
import cities from '../../data/cities.json';

export function getStaticPaths() {
  return counties.map(county => ({
    params: { 
      county: `${county.name.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}-${county.state.toLowerCase()}` 
    },
    props: { countyData: county }
  }));
}

const { countyData } = Astro.props;
const { name, full_name, fips, state, state_name, lat, lng, population } = countyData;

// Find cities in this county from our cities data
const countyCities = cities.filter(c => 
  c.county && c.county.toLowerCase().includes(name.toLowerCase()) ||
  name.toLowerCase().includes(c.county?.toLowerCase() || '')
).slice(0, 10);

// JSON-LD
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "AdministrativeArea",
  "name": full_name,
  "description": `${full_name}, ${state_name} with population of ${population.toLocaleString()}.`,
  "url": `https://getuscompliance.com/county/${name.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}-${state.toLowerCase()}`,
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": lat,
    "longitude": lng
  },
  "address": {
    "@type": "PostalAddress",
    "addressRegion": state,
    "addressCountry": "US"
  },
  "population": population
};
---

<Layout 
  title={`${full_name}, ${state_name} - Complete Guide (2026)`}
  description={`Complete guide to ${full_name}, ${state_name}. Population: ${population.toLocaleString()}. County information, cities, demographics, and local SEO resources.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  
  <div class="max-w-5xl mx-auto px-4 py-8">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-600 mb-6">
      <a href="/" class="hover:text-blue-600">Home</a> / 
      <a href={`/state/${state_name.toLowerCase().replace(/\s+/g, '-')}`} class="hover:text-blue-600">{state_name}</a> / 
      <span class="text-gray-900">{full_name}</span>
    </nav>

    <!-- Header -->
    <header class="mb-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">{full_name}</h1>
      <p class="text-xl text-gray-600">
        County in <strong>{state_name}</strong> | 
        Population: <strong>{population.toLocaleString()}</strong> |
        FIPS: <strong>{fips}</strong>
      </p>
    </header>

    <!-- Quick Stats -->
    <section class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-blue-50 p-4 rounded-lg text-center">
        <p class="text-sm text-gray-600">Population</p>
        <p class="text-2xl font-bold text-blue-600">{population.toLocaleString()}</p>
      </div>
      <div class="bg-green-50 p-4 rounded-lg text-center">
        <p class="text-sm text-gray-600">State</p>
        <p class="text-2xl font-bold text-green-600">{state_name}</p>
      </div>
      <div class="bg-purple-50 p-4 rounded-lg text-center">
        <p class="text-sm text-gray-600">FIPS Code</p>
        <p class="text-2xl font-bold text-purple-600">{fips}</p>
      </div>
      <div class="bg-orange-50 p-4 rounded-lg text-center">
        <p class="text-sm text-gray-600">Coordinates</p>
        <p class="text-2xl font-bold text-orange-600">{lat.toFixed(2)}°, {lng.toFixed(2)}°</p>
      </div>
    </section>

    <!-- Location -->
    <section class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-2xl font-bold mb-4">📍 Location</h2>
      <p class="text-gray-600">
        {full_name} is located in the state of <strong>{state_name}</strong> (State ID: {state}).
        Geographic coordinates: <strong>{lat.toFixed(4)}°N, {Math.abs(lng).toFixed(4)}°{lng < 0 ? 'W' : 'E'}</strong>.
      </p>
    </section>

    <!-- Cities in County -->
    {countyCities.length > 0 && (
      <section class="bg-white rounded-lg shadow-md p-6 mb-8">
        <h2 class="text-2xl font-bold mb-4">🏙️ Cities in {name} County</h2>
        <p class="text-gray-600 mb-4">Major cities located in {full_name}</p>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
          {countyCities.map((city) => (
            <a href={`/city/${city.city.toLowerCase().replace(/\s+/g, '-')}-${city.state_abbr.toLowerCase()}`} class="block p-4 border rounded-lg hover:border-blue-500 hover:bg-blue-50">
              <h3 class="font-semibold text-blue-600">{city.city}, {city.state_abbr}</h3>
              <p class="text-sm text-gray-600">Pop: {city.population.toLocaleString()}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- More Cities in State -->
    <section class="bg-white rounded-lg shadow-md p-4 md:p-6">
      <h2 class="text-xl md:text-2xl font-bold mb-4">🗺️ More Cities in {state_name}</h2>
      <a href={`/state/${state_name.toLowerCase().replace(/\s+/g, '-')}`} class="inline-block bg-blue-600 text-white px-5 py-3 md:px-6 md:py-3 rounded-lg hover:bg-blue-700 text-base md:text-lg w-full md:w-auto text-center no-select">
        View All {state_name} Cities →
      </a>
    </section>
  </div>
</Layout>
