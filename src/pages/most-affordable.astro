---
import Layout from '../layouts/Layout.astro';
import cities from '../data/cities.json';

// Most affordable: lowest home prices
const affordable = cities.filter(c => c.median_home_value && c.population > 20000).sort((a, b) => a.median_home_value - b.median_home_value).slice(0, 30);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Most Affordable Cities in US - Lowest Home Prices",
  "description": "Most affordable US cities with lowest home prices. Find cheap places to live."
};
---

<Layout title="Most Affordable Cities in US (2026) - Lowest Home Prices" description="Most affordable US cities with lowest home prices. Find cheap places to live.">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  
  <div class="max-w-5xl mx-auto px-4 py-8">
    <header class="mb-12 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Most Affordable Cities in US</h1>
      <p class="text-xl text-gray-600">Lowest home prices - best value for homebuyers</p>
    </header>

    <div class="bg-green-50 p-6 rounded-lg mb-8">
      <p class="text-lg">💰 <strong>Affordability:</strong> Based on median home prices. Lower is more affordable.</p>
    </div>

    <section class="bg-white rounded-lg shadow-md overflow-hidden">
      <table class="w-full">
        <thead class="bg-green-600 text-white">
          <tr>
            <th class="p-4 text-left">Rank</th>
            <th class="p-4 text-left">City</th>
            <th class="p-4 text-right">Median Home</th>
            <th class="p-4 text-right">Median Rent</th>
            <th class="p-4 text-right">Population</th>
            <th class="p-4 text-right">Crime Index</th>
          </tr>
        </thead>
        <tbody>
          {affordable.map((city, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
              <td class="p-4 font-bold text-green-600">{i + 1}</td>
              <td class="p-4">
                <a href={`/city/${city.city.toLowerCase().replace(/\s+/g, '-')}-${city.state_abbr.toLowerCase()}`} class="text-blue-600 hover:underline font-semibold">
                  {city.city}, {city.state_abbr}
                </a>
              </td>
              <td class="p-4 text-right font-bold text-green-600">${(city.median_home_value || 0).toLocaleString()}</td>
              <td class="p-4 text-right">${city.median_rent || 'N/A'}/mo</td>
              <td class="p-4 text-right">{city.population?.toLocaleString()}</td>
              <td class="p-4 text-right">{city.crime_index || 'N/A'}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <div class="mt-8 bg-blue-50 p-6 rounded-lg">
      <h2 class="text-xl font-bold mb-4">💵 Understanding Affordability</h2>
      <p class="text-gray-600">Affordability is measured by median home prices. These cities offer the best value for homebuyers and renters. However, consider job markets, amenities, and quality of life when making relocation decisions.</p>
    </div>
  </div>
</Layout>