---
import Layout from '../layouts/Layout.astro';
import cities from '../data/cities.json';

const states = [...new Set(cities.map(c => c.state))].sort();
const stateCounts = states.map(state => ({
  name: state,
  count: cities.filter(c => c.state === state).length
}));

const popularCities = cities.slice(0, 12);
---

<Layout title="US City Data Hub - Cost of Living, Crime Rates & Demographics">
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-blue-600 to-blue-800 text-white py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">
        Search Any US City for Cost of Living, Crime Rates & Demographics
      </h1>
      <p class="text-xl mb-8 text-blue-100">
        Comprehensive data for over {cities.length} US cities. Get detailed insights on housing, safety, climate, education, and more.
      </p>
      
      <!-- Search Box -->
      <div class="max-w-2xl mx-auto">
        <input 
          type="text" 
          placeholder="Enter city name..." 
          class="w-full px-6 py-4 rounded-lg text-gray-900 text-lg focus:outline-none focus:ring-4 focus:ring-blue-300"
        />
      </div>
    </div>
  </section>

  <!-- Stats Banner -->
  <section class="bg-gray-100 py-8">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
        <div>
          <p class="text-3xl font-bold text-blue-600">{cities.length}</p>
          <p class="text-gray-600">Cities</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-blue-600">{states.length}</p>
          <p class="text-gray-600">States</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-blue-600">{cities.reduce((sum, c) => sum + c.population, 0).toLocaleString()}</p>
          <p class="text-gray-600">Total Population</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-blue-600">100%</p>
          <p class="text-gray-600">Free Data</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Popular Cities -->
  <section class="py-16 max-w-7xl mx-auto px-4">
    <h2 class="text-3xl font-bold text-center mb-4">🏙️ Popular Cities</h2>
    <p class="text-gray-600 text-center mb-12">Explore our most viewed cities</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {popularCities.map((city) => (
        <a 
          href={`/city/${city.city.toLowerCase().replace(/\s+/g, '-')}-${city.state_abbr.toLowerCase()}`}
          class="block bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow border border-gray-100"
        >
          <h3 class="text-xl font-semibold text-blue-600 mb-2">{city.city}, {city.state_abbr}</h3>
          <p class="text-sm text-gray-500 mb-3">Population: {city.population.toLocaleString()}</p>
          <div class="grid grid-cols-2 gap-2 text-sm">
            <div>
              <p class="text-gray-400">Median Home</p>
              <p class="font-semibold">${(city.median_home_value/1000).toFixed(0)}K</p>
            </div>
            <div>
              <p class="text-gray-400">Livability</p>
              <p class="font-semibold">{city.livability_score}/10</p>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- All States -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-4">🗺️ Browse by State</h2>
      <p class="text-gray-600 text-center mb-12">Find cities in your state</p>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {stateCounts.map((s) => (
          <a 
            href={`/state/${s.name.toLowerCase().replace(/\s+/g, '-')}`}
            class="bg-white rounded-lg shadow p-4 hover:shadow-md transition-shadow flex justify-between items-center"
          >
            <span class="font-medium text-gray-700">{s.name}</span>
            <span class="text-sm bg-blue-100 text-blue-600 px-2 py-1 rounded-full">{s.count}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Use Our Data -->
  <section class="py-16 max-w-7xl mx-auto px-4">
    <h2 class="text-3xl font-bold text-center mb-12">📊 Why Use Our City Data?</h2>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="text-center">
        <div class="text-4xl mb-4">💰</div>
        <h3 class="text-xl font-bold mb-2">Cost of Living</h3>
        <p class="text-gray-600">Compare housing costs, rent prices, and living expenses across different cities.</p>
      </div>
      <div class="text-center">
        <div class="text-4xl mb-4">🔒</div>
        <h3 class="text-xl font-bold mb-2">Safety Data</h3>
        <p class="text-gray-600">Get crime statistics and safety ratings for informed decisions.</p>
      </div>
      <div class="text-center">
        <div class="text-4xl mb-4">🌤️</div>
        <h3 class="text-xl font-bold mb-2">Climate Info</h3>
        <p class="text-gray-600">Learn about weather patterns and climate conditions in each city.</p>
      </div>
    </div>
  </section>
</Layout>
