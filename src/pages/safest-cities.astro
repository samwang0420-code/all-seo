---
import Layout from '../layouts/Layout.astro';
import cities from '../data/cities.json';

// Cities with lowest crime (safest)
const safest = cities.filter(c => c.crime_index && c.population > 30000).sort((a, b) => a.crime_index - b.crime_index).slice(0, 30);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Safest Cities in US - Lowest Crime Rates",
  "description": "Top safest US cities with lowest crime rates. Find the most secure places to live."
};
---

<Layout title="Safest Cities in US (2026) - Lowest Crime Rates" description="Safest US cities with lowest crime rates. Find the most secure places to live.">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  
  <div class="max-w-5xl mx-auto px-4 py-8">
    <header class="mb-12 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Safest Cities in US</h1>
      <p class="text-xl text-gray-600">Cities with lowest crime rates - most secure places to live</p>
    </header>

    <div class="bg-green-50 p-6 rounded-lg mb-8">
      <p class="text-lg">🛡️ <strong>Crime Index:</strong> Lower is safer. Index ranges from 0-100+.</p>
    </div>

    <section class="bg-white rounded-lg shadow-md overflow-hidden">
      <table class="w-full">
        <thead class="bg-green-600 text-white">
          <tr>
            <th class="p-4 text-left">Rank</th>
            <th class="p-4 text-left">City</th>
            <th class="p-4 text-right">Crime Index</th>
            <th class="p-4 text-right">Population</th>
            <th class="p-4 text-right">Median Home</th>
            <th class="p-4 text-right">Livability</th>
          </tr>
        </thead>
        <tbody>
          {safest.map((city, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
              <td class="p-4 font-bold text-green-600">{i + 1}</td>
              <td class="p-4">
                <a href={`/city/${city.city.toLowerCase().replace(/\s+/g, '-')}-${city.state_abbr.toLowerCase()}`} class="text-blue-600 hover:underline font-semibold">
                  {city.city}, {city.state_abbr}
                </a>
              </td>
              <td class="p-4 text-right font-bold text-green-600">{city.crime_index}</td>
              <td class="p-4 text-right">{city.population?.toLocaleString()}</td>
              <td class="p-4 text-right">${(city.median_home_value || 0).toLocaleString()}</td>
              <td class="p-4 text-right">{city.livability_score || 'N/A'}/10</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <div class="mt-8 bg-blue-50 p-6 rounded-lg">
      <h2 class="text-xl font-bold mb-4">📊 Crime Index Methodology</h2>
      <p class="text-gray-600">Crime index is calculated using FBI Uniform Crime Reporting (UCR) data. Lower numbers indicate safer areas. Our index uses a 0-100+ scale where lower is better. Cities with populations over 30,000 are included for statistical reliability.</p>
    </div>
  </div>
</Layout>