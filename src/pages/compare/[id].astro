---
import Layout from '../../layouts/Layout.astro';
import comparisons from '../../data/city_comparisons.json';

export function getStaticPaths() {
  return comparisons.map((comp, i) => ({
    params: { id: String(i + 1) },
    props: { comparison: comp }
  }));
}

const { comparison } = Astro.props;
const { city1, state1, city2, state2, pop1, pop2, home1, home2, rent1, rent2, crime1, crime2 } = comparison;

const title = `${city1}, ${state1} vs ${city2}, ${state2} - Compare Cost of Living, Population & Safety`;
const description = `Compare ${city1}, ${state1} and ${city2}, ${state2}: population, median home price, rent, crime rates, and livability.`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description
};
---

<Layout title={`${title} (2026)`} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  
  <div class="max-w-5xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-600 mb-6">
      <a href="/" class="hover:text-blue-600">Home</a> / 
      <span class="text-gray-900">City Comparison</span>
    </nav>

    <header class="mb-8">
      <h1 class="text-3xl md:text-5xl font-bold mb-4">{city1}, {state1} vs {city2}, {state2}</h1>
      <p class="text-xl text-gray-600">Side-by-side comparison of cost of living, population, and safety</p>
    </header>

    <div class="grid md:grid-cols-2 gap-8 mb-8">
      <!-- City 1 -->
      <div class="bg-white rounded-lg shadow-lg p-6">
        <h2 class="text-2xl font-bold mb-4 text-blue-600">{city1}, {state1}</h2>
        <div class="space-y-4">
          <div class="flex justify-between border-b pb-2">
            <span class="text-gray-600">Population</span>
            <span class="font-semibold">{pop1?.toLocaleString() || 'N/A'}</span>
          </div>
          <div class="flex justify-between border-b pb-2">
            <span class="text-gray-600">Median Home</span>
            <span class="font-semibold">${home1?.toLocaleString() || 'N/A'}</span>
          </div>
          <div class="flex justify-between border-b pb-2">
            <span class="text-gray-600">Median Rent</span>
            <span class="font-semibold">${rent1?.toLocaleString() || 'N/A'}/mo</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-600">Crime Index</span>
            <span class="font-semibold">{crime1 || 'N/A'}</span>
          </div>
        </div>
        <a href={`/city/${city1.toLowerCase().replace(/\s+/g, '-')}-${state1.toLowerCase()}`} class="block mt-4 text-center bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700">
          View Full Profile →
        </a>
      </div>

      <!-- City 2 -->
      <div class="bg-white rounded-lg shadow-lg p-6">
        <h2 class="text-2xl font-bold mb-4 text-green-600">{city2}, {state2}</h2>
        <div class="space-y-4">
          <div class="flex justify-between border-b pb-2">
            <span class="text-gray-600">Population</span>
            <span class="font-semibold">{pop2?.toLocaleString() || 'N/A'}</span>
          </div>
          <div class="flex justify-between border-b pb-2">
            <span class="text-gray-600">Median Home</span>
            <span class="font-semibold">${home2?.toLocaleString() || 'N/A'}</span>
          </div>
          <div class="flex justify-between border-b pb-2">
            <span class="text-gray-600">Median Rent</span>
            <span class="font-semibold">${rent2?.toLocaleString() || 'N/A'}/mo</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-600">Crime Index</span>
            <span class="font-semibold">{crime2 || 'N/A'}</span>
          </div>
        </div>
        <a href={`/city/${city2.toLowerCase().replace(/\s+/g, '-')}-${state2.toLowerCase()}`} class="block mt-4 text-center bg-green-600 text-white py-2 rounded-lg hover:bg-green-700">
          View Full Profile →
        </a>
      </div>
    </div>

    <!-- Summary -->
    <section class="bg-gray-50 rounded-lg p-6">
      <h2 class="text-2xl font-bold mb-4">📊 Quick Summary</h2>
      <div class="grid md:grid-cols-3 gap-4">
        <div class="text-center p-4 bg-white rounded">
          <p class="text-gray-600 mb-1">Population Difference</p>
          <p class="text-xl font-bold">{Math.abs(pop1 - pop2).toLocaleString()}</p>
        </div>
        <div class="text-center p-4 bg-white rounded">
          <p class="text-gray-600 mb-1">Home Price Difference</p>
          <p class="text-xl font-bold">${Math.abs(home1 - home2).toLocaleString()}</p>
        </div>
        <div class="text-center p-4 bg-white rounded">
          <p class="text-gray-600 mb-1">Rent Difference</p>
          <p class="text-xl font-bold">${Math.abs(rent1 - rent2).toLocaleString()}/mo</p>
        </div>
      </div>
    </section>
  </div>
</Layout>